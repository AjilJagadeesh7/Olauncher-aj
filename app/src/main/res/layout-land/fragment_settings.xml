<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainActivityLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sheet_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/scrollLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="40dp">

            <View
                android:layout_width="42dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="14dp"
                android:background="#40808080" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_rect_shade_color"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp">

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView android:id="@+id/olauncherHiddenApps" style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/hidden_apps" android:textColor="?attr/primaryColor" />
                    <TextView style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:text=">" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView android:id="@+id/setLauncher" style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/set_as_default_launcher" android:textColor="?attr/primaryColor" />
                </FrameLayout>
            </LinearLayout>

            <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp" android:letterSpacing="0.10" android:text="@string/appearance" android:textAllCaps="true" android:textColor="?attr/primaryColorTrans50" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_rect_shade_color"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp">

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/auto_show_keyboard" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/autoShowKeyboard" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:text="@string/on" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/daily_wallpaper_update" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/dailyWallpaper" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:text="@string/off" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/notification_bar" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/statusBar" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:text="@string/off" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/theme_mode" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/appThemeText" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:text="@string/dark" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/clock_style" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/clockStyle" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:text="@string/style_minimal" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/wave_style" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/waveStyle" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" android:text="@string/wave_balanced" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="50dp"
                    android:paddingVertical="8dp">

                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/text_size" android:textColor="?attr/primaryColor" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:id="@+id/textSizesLayout"
                        android:layout_width="176dp"
                        android:layout_height="36dp"
                        android:background="@drawable/rounded_rectangle_dark"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp"
                        android:visibility="visible">

                        <TextView android:id="@+id/textSizeMinus" style="@style/TextSmallBold" android:layout_width="44dp" android:layout_height="match_parent" android:gravity="center" android:text="−" />
                        <TextView android:id="@+id/textSizeCurrent" style="@style/TextSmallBold" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="1.0" />
                        <TextView android:id="@+id/textSizePlus" style="@style/TextSmallBold" android:layout_width="44dp" android:layout_height="match_parent" android:gravity="center" android:text="+" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textSizeValue"
                        style="@style/TextSmallBold"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp" android:letterSpacing="0.10" android:text="@string/gestures" android:textAllCaps="true" android:textColor="?attr/primaryColorTrans50" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_rect_shade_color"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp">

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/swipe_left_app" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/swipeLeftApp" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/swipe_right_app" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/swipeRightApp" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/swipe_down_for" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/swipeDownAction" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/double_tap_to_lock_screen" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/toggleLock" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="18dp"
                android:background="@drawable/rounded_rect_shade_color"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp">

                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/home_button_show_recents" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/homeButtonRecents" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/screen_time" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/screenTimeOnOff" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/app_icons" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/showIcons" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/battery" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/batteryLevel" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="?attr/primaryColorTrans50" />
                <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="50dp">
                    <TextView style="@style/TextSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="@string/font" android:textColor="?attr/primaryColor" />
                    <TextView android:id="@+id/fontFamily" style="@style/TextSmallBold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end|center_vertical" />
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/appInfo"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:alpha="0.72"
                android:text="@string/based_on_olauncher_note"
                android:textColor="?attr/primaryColorTrans50" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
